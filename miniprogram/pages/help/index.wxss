page {
  min-height: 100vh;
  background: #f5f4ef;
  color: #1d1d1b;
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 56rpx 42rpx 80rpx;
  box-sizing: border-box;
}

.hero {
  padding: 34rpx 4rpx 28rpx;
}

.title {
  color: #1d1d1b;
  font-size: 46rpx;
  line-height: 1.22;
  font-weight: 800;
}

.subtitle {
  margin-top: 14rpx;
  color: #696967;
  font-size: 27rpx;
  line-height: 1.55;
}

.steps-card,
.help-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 6rpx 22rpx rgba(29, 29, 27, 0.055);
}

.step-item {
  display: flex;
  gap: 22rpx;
}

.step-item + .step-item {
  margin-top: 34rpx;
}

.step-number {
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #6f7b59;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-content {
  flex: 1;
  min-width: 0;
}

.step-title,
.card-title {
  color: #1d1d1b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
}

.step-desc,
.help-text,
.help-tip {
  margin-top: 10rpx;
  color: #696967;
  font-size: 25rpx;
  line-height: 1.55;
}

.inline-code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  color: #465037;
  font-weight: 800;
}

.tutorial-box,
.wechat-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f5f4ef;
  color: #1d1d1b;
  font-size: 25rpx;
  line-height: 1.45;
  word-break: break-all;
}

.wechat-box {
  height: 78rpx;
  padding: 0 22rpx;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 82rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-button::after,
.secondary-button::after {
  border: 0;
}

.primary-button {
  background: #6f7b59;
  color: #ffffff;
}

.secondary-button {
  background: #f5f4ef;
  color: #1d1d1b;
}
