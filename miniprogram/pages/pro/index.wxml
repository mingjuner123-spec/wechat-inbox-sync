<view class="page">
  <view class="trial-card">
    <view class="eyebrow">{{membership.badge}}</view>
    <view class="trial-title">{{membership.title}}</view>
    <view wx:if="{{membership.desc}}" class="trial-desc">{{membership.desc}}</view>
    <view wx:if="{{showMembershipExpiry && !showRedeemCode}}" class="trial-expiry active">
      有效期至 {{membership.expiresLabel}}
    </view>
    <view wx:if="{{showTrialClaim}}" class="trial-desc">点击后会直接开通 7 天体验，不需要再输入兑换码。</view>

    <button
      wx:if="{{showTrialClaim}}"
      class="primary-button"
      disabled="{{trialCodeLoading}}"
      bindtap="claimTrialRedeemCode"
    >
      {{trialCodeLoading ? '开通中' : '领取 7 天 Pro 体验'}}
    </button>

    <block wx:if="{{showRedeemCode}}">
      <view class="trial-code-label">兑换码</view>
      <view class="trial-code-box">{{trialRedeemCode}}</view>
      <view wx:if="{{trialRedeemCodeExpiresLabel && !trialRedeemCodeExpired}}" class="trial-expiry">
        有效期至 {{trialRedeemCodeExpiresLabel}}
      </view>
      <view wx:if="{{trialRedeemCodeExpiresLabel && trialRedeemCodeExpired}}" class="trial-expiry expired">
        该兑换码已到期，请联系张张续期。
      </view>
      <button class="trial-copy-button" bindtap="copyTrialRedeemCode">一键复制兑换码</button>
    </block>
  </view>

  <view class="compare-card payment-card">
    <view class="card-kicker">早鸟价</view>
    <view class="card-title">{{membership.paymentTitle}}</view>
    <view class="redeem-desc">选择月卡或年卡后，会直接拉起微信虚拟支付。支付后请等待订单确认，权益刷新后即可使用。</view>
    <view class="payment-plan-list">
      <view
        wx:for="{{paymentPlans}}"
        wx:key="id"
        class="payment-plan {{selectedPaymentPlanId === item.id ? 'selected' : ''}}"
        data-plan-id="{{item.id}}"
        bindtap="selectPaymentPlan"
      >
        <view class="payment-plan-main">
          <view class="payment-plan-head">
            <view class="payment-plan-name">{{item.name}}</view>
            <view wx:if="{{item.badge}}" class="payment-plan-badge">{{item.badge}}</view>
          </view>
          <view class="payment-plan-desc">{{item.desc}}</view>
        </view>
        <view class="payment-plan-price">{{item.price}}</view>
      </view>
    </view>
    <view class="price-reset-tip">早鸟价截止到 7 月 10 日，之后恢复原价：月卡 19.9 元/月，年卡 68 元/年。</view>
    <button class="primary-button pay-button" disabled="{{paymentOrderLoading}}" bindtap="createFormalPaymentOrder">
      {{paymentOrderLoading ? '拉起支付中' : membership.paymentButtonText}}
    </button>
    <view wx:if="{{latestPaymentOrder}}" class="payment-order-tip">
      已生成订单：{{latestPaymentOrder.orderNo}} · {{latestPaymentOrder.amountText}} · {{latestPaymentOrder.status}}
    </view>
  </view>

</view>
