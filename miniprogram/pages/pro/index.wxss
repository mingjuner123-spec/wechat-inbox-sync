page {
  min-height: 100vh;
  background: #f5f4ef;
  color: #1d1d1b;
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 56rpx 42rpx 80rpx;
  box-sizing: border-box;
}

.trial-card,
.compare-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 6rpx 22rpx rgba(29, 29, 27, 0.055);
}

.trial-card {
  margin-top: 0;
  background: #1f2719;
  color: #ffffff;
}

.eyebrow {
  display: inline-flex;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.trial-title,
.card-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
}

.card-kicker {
  display: inline-flex;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: #1f2719;
  color: #f8f4df;
  font-size: 21rpx;
  font-weight: 900;
}

.card-kicker + .card-title {
  margin-top: 16rpx;
}

.trial-title {
  margin-top: 22rpx;
  font-size: 44rpx;
}

.trial-desc,
.redeem-desc {
  margin-top: 12rpx;
  color: #696967;
  font-size: 25rpx;
  line-height: 1.55;
}

.trial-desc {
  color: rgba(255, 255, 255, 0.74);
}

.primary-button,
.trial-copy-button {
  width: 100%;
  height: 82rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-button::after,
.trial-copy-button::after {
  border: 0;
}

.primary-button,
.trial-copy-button {
  background: #ffffff;
  color: #1f2719;
}

.payment-card {
  background: #fffaf0;
}

.payment-plan-list {
  margin-top: 22rpx;
  display: grid;
  gap: 16rpx;
}

.payment-plan {
  min-height: 126rpx;
  padding: 24rpx 22rpx;
  border-radius: 18rpx;
  border: 2rpx solid #e8dfc6;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.payment-plan.selected {
  border-color: #1f2719;
  box-shadow: 0 8rpx 22rpx rgba(31, 39, 25, 0.12);
}

.payment-plan-main {
  min-width: 0;
}

.payment-plan-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.payment-plan-name {
  color: #1d1d1b;
  font-size: 28rpx;
  font-weight: 900;
}

.payment-plan-badge {
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f1c66a;
  color: #3e3216;
  font-size: 20rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.payment-plan-desc {
  margin-top: 8rpx;
  color: #6b665a;
  font-size: 23rpx;
  line-height: 1.4;
}

.payment-plan-price {
  flex: 0 0 auto;
  color: #1f2719;
  font-size: 32rpx;
  font-weight: 900;
}

.price-reset-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(241, 198, 106, 0.18);
  color: #6d5621;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 700;
}

.pay-button {
  background: #1f2719;
  color: #ffffff;
}

.payment-order-tip {
  margin-top: 18rpx;
  color: #6b665a;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.trial-code-label {
  margin-top: 28rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
  font-weight: 800;
}

.trial-code-box {
  min-height: 88rpx;
  margin-top: 14rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: break-all;
  text-align: center;
}

.trial-expiry {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 700;
}

.trial-expiry.active {
  display: inline-flex;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: rgba(255, 255, 255, 0.13);
  color: #ffffff;
}

.trial-expiry.expired {
  color: #ffd4c8;
}
