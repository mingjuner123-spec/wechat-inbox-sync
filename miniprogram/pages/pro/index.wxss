page {
  min-height: 100vh;
  background: #f5f4ef;
  color: #1d1d1b;
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 56rpx 42rpx 80rpx;
  box-sizing: border-box;
}

.hero {
  padding: 34rpx 4rpx 28rpx;
}

.eyebrow {
  display: inline-flex;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: #1f2719;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 22rpx;
  color: #1d1d1b;
  font-size: 46rpx;
  line-height: 1.22;
  font-weight: 800;
}

.subtitle {
  margin-top: 14rpx;
  color: #696967;
  font-size: 27rpx;
  line-height: 1.55;
}

.trial-card,
.compare-card,
.redeem-card,
.note-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 6rpx 22rpx rgba(29, 29, 27, 0.055);
}

.trial-card {
  background: #1f2719;
  color: #ffffff;
}

.trial-title,
.card-title,
.note-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
}

.trial-desc,
.redeem-desc,
.note-text {
  margin-top: 12rpx;
  color: #696967;
  font-size: 25rpx;
  line-height: 1.55;
}

.trial-desc {
  color: rgba(255, 255, 255, 0.74);
}

.primary-button,
.secondary-button,
.ghost-button {
  width: 100%;
  height: 82rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-button::after,
.secondary-button::after,
.ghost-button::after {
  border: 0;
}

.primary-button {
  background: #ffffff;
  color: #1f2719;
}

.secondary-button {
  background: #6f7b59;
  color: #ffffff;
}

.ghost-button {
  margin-top: 12rpx;
  background: transparent;
  color: #8a8a89;
}

.plan-block {
  margin-top: 24rpx;
}

.plan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.plan-badge {
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.plan-badge.free {
  background: #e8ebe3;
  color: #465037;
}

.plan-badge.pro {
  background: #1f2719;
  color: #ffffff;
}

.plan-desc {
  color: #696967;
  font-size: 24rpx;
  font-weight: 700;
}

.feature-row {
  min-height: 54rpx;
  padding-left: 28rpx;
  color: #1d1d1b;
  font-size: 26rpx;
  line-height: 1.5;
  display: flex;
  align-items: center;
  position: relative;
}

.feature-row::before {
  content: "";
  position: absolute;
  left: 0;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #6f7b59;
}

.divider {
  height: 1rpx;
  background: #f0eee8;
  margin: 28rpx 0 4rpx;
}

.redeem-input {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f5f4ef;
  color: #1d1d1b;
  font-size: 30rpx;
  text-align: center;
}

.placeholder {
  color: rgba(138, 138, 137, 0.64);
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(29, 29, 27, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.contact-panel {
  width: 100%;
  padding: 40rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
}

.contact-title {
  color: #1d1d1b;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.contact-desc,
.contact-tip {
  margin-top: 14rpx;
  color: #696967;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}

.wechat-box {
  margin-top: 28rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: #f5f4ef;
  color: #1d1d1b;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}
