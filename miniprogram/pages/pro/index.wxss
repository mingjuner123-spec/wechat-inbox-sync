page {
  min-height: 100vh;
  background: #f5f4ef;
  color: #1d1d1b;
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 56rpx 42rpx 80rpx;
  box-sizing: border-box;
}

.trial-card,
.compare-card,
.tutorial-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 6rpx 22rpx rgba(29, 29, 27, 0.055);
}

.trial-card {
  margin-top: 0;
  background: #1f2719;
  color: #ffffff;
}

.eyebrow {
  display: inline-flex;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.trial-title,
.card-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
}

.trial-title {
  margin-top: 22rpx;
  font-size: 44rpx;
}

.trial-desc,
.redeem-desc {
  margin-top: 12rpx;
  color: #696967;
  font-size: 25rpx;
  line-height: 1.55;
}

.trial-desc {
  color: rgba(255, 255, 255, 0.74);
}

.primary-button,
.secondary-button,
.trial-copy-button,
.ghost-button {
  width: 100%;
  height: 82rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-button::after,
.secondary-button::after,
.trial-copy-button::after,
.ghost-button::after {
  border: 0;
}

.primary-button,
.trial-copy-button {
  background: #ffffff;
  color: #1f2719;
}

.secondary-button {
  background: #6f7b59;
  color: #ffffff;
}

.ghost-button {
  margin-top: 14rpx;
  background: #e8ebe3;
  color: #465037;
}

.payment-card {
  background: #fff8e7;
}

.payment-plan-list {
  margin-top: 22rpx;
  display: grid;
  gap: 16rpx;
}

.payment-plan {
  padding: 24rpx;
  border-radius: 22rpx;
  border: 2rpx solid #eadfbe;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.payment-plan.selected {
  border-color: #1f2719;
  box-shadow: 0 8rpx 22rpx rgba(31, 39, 25, 0.12);
}

.payment-plan-name {
  color: #1d1d1b;
  font-size: 28rpx;
  font-weight: 900;
}

.payment-plan-desc {
  margin-top: 8rpx;
  color: #6b665a;
  font-size: 23rpx;
  line-height: 1.4;
}

.payment-plan-price {
  flex: 0 0 auto;
  color: #1f2719;
  font-size: 32rpx;
  font-weight: 900;
}

.pay-button {
  background: #1f2719;
  color: #ffffff;
}

.payment-order-tip {
  margin-top: 18rpx;
  color: #6b665a;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.trial-code-label {
  margin-top: 28rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
  font-weight: 800;
}

.trial-code-box {
  min-height: 88rpx;
  margin-top: 14rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: break-all;
  text-align: center;
}

.trial-expiry {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 700;
}

.trial-expiry.expired {
  color: #ffd4c8;
}

.benefit-table {
  margin-top: 24rpx;
  border: 1rpx solid #e8e4d9;
  border-radius: 18rpx;
  overflow: hidden;
  background: #ffffff;
}

.benefit-table-header,
.benefit-table-row {
  min-height: 78rpx;
  display: grid;
  grid-template-columns: 1.15fr 1fr 1fr;
  border-bottom: 1rpx solid #eee9df;
}

.benefit-table-row:last-child {
  border-bottom: 0;
}

.benefit-table-header {
  background: #f0eee7;
  font-weight: 800;
}

.benefit-cell {
  min-width: 0;
  padding: 18rpx 14rpx;
  box-sizing: border-box;
  color: #3f3f3c;
  font-size: 24rpx;
  line-height: 1.35;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-right: 1rpx solid #eee9df;
  word-break: break-word;
}

.benefit-cell:last-child {
  border-right: 0;
}

.benefit-name {
  justify-content: flex-start;
  text-align: left;
  color: #1d1d1b;
  font-weight: 800;
}

.pro-col {
  color: #5c6845;
  font-weight: 800;
}

.tutorial-step {
  margin-top: 28rpx;
}

.tutorial-step-title {
  color: #1d1d1b;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
}

.tutorial-image {
  width: 100%;
  margin-top: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid #eee9df;
  background: #ffffff;
}

.tutorial-actions {
  margin-top: 30rpx;
}
